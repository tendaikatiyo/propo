{
  "name": "propo",
  "version": "1.0.0",
  "description": "Property intelligence prototype for Zimbabwe",
  "type": "module",
  "scripts": {
    "scrape": "node scraper/scrape.js",
    "scrape:rentals": "python scraper/propertybook_rentals.py",
    "scrape:sales": "python scraper/propertybook_sales.py",
    "analytics:clean": "python analytics/clean_data.py",
    "analytics:metrics": "python analytics/market_metrics.py",
    "analytics:cities": "python analytics/city_metrics.py",
    "analytics:rankings": "python analytics/rankings.py",
    "analytics:build": "npm run analytics:clean && npm run analytics:metrics && npm run analytics:cities && npm run analytics:rankings",
    "scrape:all": "python -m scraper.scrape_all",
    "pipeline:ingest": "python -m analytics.ingest",
    "pipeline:daily": "python -m analytics.daily_metrics",
    "pipeline:run": "python -m analytics.run_pipeline",
    "pipeline:cloud": "python -m analytics.run_pipeline && npm run analytics:build && python -m analytics.ingest_supabase && python -m analytics.sync_dashboard",
    "pipeline:supabase": "python -m analytics.ingest_supabase && python -m analytics.sync_dashboard",
    "normalize": "node scraper/normalize.js",
    "aggregate": "node scraper/aggregate.js",
    "build": "npm run scrape && npm run normalize && npm run aggregate"
  },
  "dependencies": {
    "dotenv": "^16.3.1",
    "@mendable/firecrawl-js": "^4.25.0",
    "zod": "^4.4.3"
  }
}
