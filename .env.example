# Supabase (server-side — VM / pipeline only)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Direct Postgres connection (required for ingest_supabase bulk writes)
# Supabase Dashboard → Project Settings → Database → Connection string → URI
# Use Session pooler (port 6543), NOT direct db.* host — direct host is often IPv6-only
# and fails on Windows/networks without IPv6.
#
# Format:
# SUPABASE_DB_URL=postgresql://postgres.PROJECT_REF:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres
#
# If password contains special characters (@, #, /, etc.), URL-encode them.
SUPABASE_DB_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres
